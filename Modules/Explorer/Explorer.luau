		local function isOverDexGui()
			local pos = service.UserInputService:GetMouseLocation()

			local function isDexGuiObject(obj)
				local gui = obj:FindFirstAncestorOfClass("ScreenGui") or obj:FindFirstAncestorOfClass("SurfaceGui")
				if not gui then return false end

				local name = gui.Name
				if string.sub(name, 1, 5) == "_DPP_" then
					return true
				end

				if gethui then
					local success, hui = pcall(gethui)
					if success and hui and (hui ~= service.CoreGui) and gui:IsDescendantOf(hui) then
						return true
					end
				end

				local standardNames = {
					Dex = true, ExplorerSelections = true,
					Intro = true, UpdatePrompt = true, Notepad = true,
					ControlCenter = true, IDESync = true, InspectorHub = true,
					TaskRouter = true, SecurityAuditor = true, RuntimeInspector = true,
					ClientIntelligence = true, ModelViewer = true, ImageViewer = true,
					SoundViewer = true, AnimationViewer = true
				}
				if standardNames[name] then
					return true
				end

				return false
			end

			local playerGui = plr:FindFirstChildOfClass("PlayerGui")
			if playerGui and playerGui.GetGuiObjectsAtPosition then
				local success, res = pcall(function() return playerGui:GetGuiObjectsAtPosition(pos.X, pos.Y) end)
				if success and res then
					for _, obj in ipairs(res) do
						if isDexGuiObject(obj) then
							return true
						end
					end
				end
			end

			local coreGui = service.CoreGui
			if coreGui and coreGui.GetGuiObjectsAtPosition then
				local success, res = pcall(function() return coreGui:GetGuiObjectsAtPosition(pos.X, pos.Y) end)
				if success and res then
					for _, obj in ipairs(res) do
						if isDexGuiObject(obj) then
							return true
						end
					end
				end
			end

			if gethui then
				local success, hui = pcall(gethui)
				if success and hui and hui ~= service.CoreGui then
					if hui.GetGuiObjectsAtPosition then
						local success2, res = pcall(function() return hui:GetGuiObjectsAtPosition(pos.X, pos.Y) end)
						if success2 and res then
							for _, obj in ipairs(res) do
								if isDexGuiObject(obj) then
									return true
								end
							end
						end
					end

					local getDescendantsSuccess, list = pcall(function() return hui:GetDescendants() end)
					if getDescendantsSuccess and list then
						for _, obj in ipairs(list) do
							if obj:IsA("GuiObject") and obj.AbsoluteSize.X > 0 and obj.AbsoluteSize.Y > 0 then
								local gui = obj:FindFirstAncestorOfClass("ScreenGui") or obj:FindFirstAncestorOfClass("SurfaceGui")
								if gui and gui.Enabled then
									local absPos = obj.AbsolutePosition
									local absSize = obj.AbsoluteSize
									if pos.X >= absPos.X and pos.X < absPos.X + absSize.X and
									   pos.Y >= absPos.Y and pos.Y < absPos.Y + absSize.Y then
										if isDexGuiObject(obj) then
											return true
										end
									end
								end
							end
						end
					end
				end
			end

			if Lib and Lib.GetActive3DPanels then
				for _, panel in ipairs(Lib.GetActive3DPanels()) do
					if panel.BillboardAdornee and panel.BillboardAdornee.Parent then
						local camera = workspace.CurrentCamera
						local mouseRay = camera:ViewportPointToRay(pos.X, pos.Y)
						local params = RaycastParams.new()
						params.FilterType = Enum.RaycastFilterType.Include
						params.FilterDescendantsInstances = {panel.BillboardAdornee}
						params.IgnoreWater = true
						local result = workspace:Raycast(mouseRay.Origin, mouseRay.Direction * 1000, params)
						if result then
							return true
						end
					end
				end
			end

			return false
		end
		Explorer.isOverDexGui = isOverDexGui

		local viewportBeganCon = nil
		local viewportEndedCon = nil
		local mouseBehaviorCon = nil

		Explorer.UpdateViewportListener = function()
			if viewportBeganCon then viewportBeganCon:Disconnect() viewportBeganCon = nil end
			if viewportEndedCon then viewportEndedCon:Disconnect() viewportEndedCon = nil end
			if mouseBehaviorCon then mouseBehaviorCon:Disconnect() mouseBehaviorCon = nil end

			if not Settings.Explorer.ViewportContextMenuEnabled then return end

			local mouse = Main.Mouse or plr:GetMouse()
			local uis = service.UserInputService
			local clickStartTime = 0
			local clickStartPos = Vector3.zero

			local function triggerSelect(position)
				if isOverDexGui() then return end

				local target = mouse.Target
				if target then
					local targetNode = nodes[target]
					local current = target
					while not targetNode and current and current ~= game do
						current = current.Parent
						targetNode = nodes[current]
					end
					if targetNode then
						selection:Set(targetNode)
						Explorer.ViewNode(targetNode)
						Explorer.Refresh()

						Explorer.ShowViewportRightClick(position, targetNode.Obj, mouse.Hit.Position)
					end
				end
			end

			local triggerType = Settings.Explorer.ViewportContextMenuTrigger
			local targetButton = (triggerType == "Right Click") and Enum.UserInputType.MouseButton2 or Enum.UserInputType.MouseButton3

			local mouseWasLocked = uis.MouseBehavior == Enum.MouseBehavior.LockCenter or uis.MouseBehavior == Enum.MouseBehavior.LockCurrentPosition

			local function updateMouseLockedState()
				if not uis:IsMouseButtonPressed(targetButton) then
					mouseWasLocked = (uis.MouseBehavior == Enum.MouseBehavior.LockCenter or uis.MouseBehavior == Enum.MouseBehavior.LockCurrentPosition)
				end
			end

			mouseBehaviorCon = uis:GetPropertyChangedSignal("MouseBehavior"):Connect(updateMouseLockedState)

			viewportBeganCon = uis.InputBegan:Connect(function(input, processed)
				if input.UserInputType == targetButton then
					clickStartTime = os.clock()
					clickStartPos = input.Position
				end
			end)

			viewportEndedCon = uis.InputEnded:Connect(function(input, processed)
				if input.UserInputType == targetButton then
					if mouseWasLocked then return end

					if triggerType == "Middle Click" then
						triggerSelect(input.Position)
					elseif triggerType == "Right Click" then
						local duration = os.clock() - clickStartTime
						local delta = (input.Position - clickStartPos).Magnitude
						if duration < 0.8 and delta < 30 then
							triggerSelect(input.Position)
						end
					end
				end
			end)
		end

		Explorer.ShowViewportRightClick = function(MousePos, targetObj, hitPosition)
			Explorer.ShowRightClick(MousePos, targetObj, hitPosition)
		end

		-- Settings
		autoUpdateSearch = Settings.Explorer.AutoUpdateSearch

		-- Fill in nodes
		nodes[game] = {Obj = game}
		expanded[nodes[game]] = true

		-- Nil Instances
		if env.getnilinstances then
			nodes[nilNode.Obj] = nilNode
		end

		-- Captured Templates
		nodes[capturedNode.Obj] = capturedNode

		Explorer.SetupConnections()
		Explorer.UpdateViewportListener()

		local insts = getDescendants(game)
		local buildYieldAt = os.clock() + 0.02
		if Main.Elevated then
			for i = 1,#insts do
				if i % 500 == 0 and os.clock() >= buildYieldAt then
					buildYieldAt = os.clock() + 0.02
					task.wait()
				end
				local obj = insts[i]
				local par = nodes[ffa(obj,"Instance")]
				if not par then continue end
				local newNode = {
					Obj = obj,
					Parent = par,
				}
				nodes[obj] = newNode
				par[#par+1] = newNode
			end
		else
			for i = 1,#insts do
				if i % 500 == 0 and os.clock() >= buildYieldAt then
					buildYieldAt = os.clock() + 0.02
					task.wait()
				end
				local obj = insts[i]
				local s,parObj = pcall(ffa,obj,"Instance")
				local par = nodes[parObj]
				if not par then continue end
				local newNode = {
					Obj = obj,
					Parent = par,
				}
				nodes[obj] = newNode
				par[#par+1] = newNode
			end
		end

		-- Auto Scan Nil Instances on startup
		task.spawn(function()
			pcall(Explorer.RefreshNilInstances)
		end)

		-- Global Undo/Redo Keyboard Shortcuts
		service.UserInputService.InputBegan:Connect(function(input, processed)
			if service.UserInputService:GetFocusedTextBox() then return end

			local ctrl = service.UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or service.UserInputService:IsKeyDown(Enum.KeyCode.RightControl)
			local shift = service.UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or service.UserInputService:IsKeyDown(Enum.KeyCode.RightShift)

			if ctrl then
				if input.KeyCode == Enum.KeyCode.Z then
					local History = Apps.History
					if History then
						if shift then
							if History.Redo then History.Redo() end
						else
							if History.Undo then History.Undo() end
						end
					end
				elseif input.KeyCode == Enum.KeyCode.Y then
					local History = Apps.History
					if History and History.Redo then
						History.Redo()
					end
				end
			end
		end)

		-- Hook __namecall for Metatable Sniffing
		if env.hookmetamethod then
			task.spawn(function()
				local oldNamecall
				oldNamecall = env.hookmetamethod(game, "__namecall", function(self, ...)
					local method = getnamecallmethod()
					if not env.checkcaller() and typeof(self) == "Instance" then
						if method == "Clone" then
							task.spawn(pcall, registerSniffedTemplate, self)
						elseif method == "FindFirstChild" or method == "WaitForChild" then
							local args = {...}
							local childName = args[1]
							if typeof(childName) == "string" then
								task.spawn(function()
									pcall(function()
										local child = game.FindFirstChild(self, childName)
										if child then
											registerSniffedTemplate(child)
										end
									end)
								end)
							end
						end
					end
					return oldNamecall(self, ...)
				end)
			end)
		end
	end

	return Explorer
end

return {InitDeps = initDeps, InitAfterMain = initAfterMain, Main = main}
